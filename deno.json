{
  "tasks": {
    "dev": "deno run --env-file=.env --watch --allow-all main.ts",
    "start": "deno run --allow-net --allow-read --allow-env main.ts",
    "test": "deno test --allow-net --allow-read"
  },
  "imports": {
    "@joyautomation/coral": "jsr:@joyautomation/coral@^0.0.12",
    "@nats-io/transport-deno": "jsr:@nats-io/transport-deno@3",
    "@nats-io/jetstream": "jsr:@nats-io/jetstream@3",
    "@nats-io/kv": "jsr:@nats-io/kv@3",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "@tentacle/nats-schema": "../nats-schema/src/mod.ts"
  },
  "compilerOptions": {
    "strict": true
  }
}
